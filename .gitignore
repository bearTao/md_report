# ============================================
# Python 编译文件和缓存
# ============================================
# 说明：这些是Python运行时自动生成的文件，不应提交到版本控制
# __pycache__/ 包含编译后的.pyc文件，每次代码变更都会重新生成
# *.pyc, *.pyo, *.pyd 都是编译后的字节码文件
__pycache__/
*.pyc


# Python 打包和分发文件
# 说明：这些是构建和发布时生成的临时文件
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================
# 虚拟环境目录
# ============================================
# 说明：虚拟环境包含大量第三方包，不应提交
# 每个开发者应该使用 requirements.txt 在本地创建自己的虚拟环境
venv/
env/
ENV/
.venv

# ============================================
# IDE 和编辑器配置
# ============================================
# 说明：每个开发者的IDE配置可能不同，不应强制统一
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# 环境变量配置文件
# ============================================
# 说明：包含敏感信息（API密钥、数据库密码等），绝对不能提交！
# 应该使用 .env.example 作为模板，让开发者复制后填入自己的配置
.env
.env.local
.env.*.local

# ============================================
# 数据库文件
# ============================================
# 说明：本地数据库文件包含开发时的测试数据，不应提交
*.db
*.sqlite
*.sqlite3

# ============================================
# 日志文件
# ============================================
# 说明：运行时生成的日志文件，不需要版本控制
*.log
logs/

# ============================================
# 测试相关文件
# ============================================
# 说明：测试运行时生成的缓存和覆盖率报告
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter Notebook
.ipynb_checkpoints

# PyCharm
.idea/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# ============================================
# 项目生成的输出文件
# ============================================
# 说明：示例脚本生成的报告和测试输出，不需要提交
*.md.backup
*_output.md
ai_test_output.log
comprehensive_report_output.md
complex_report_output.md
ai_report_output.md

